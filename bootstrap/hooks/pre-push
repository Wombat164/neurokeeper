#!/usr/bin/env bash
# claude-harness pre-push OPSEC guard.
#
# The private dev history may carry sensitive keywords; ONLY the clean release line may reach a PUBLIC
# (github) remote. This hook refuses a push to github if the OPSEC keyword scan finds anything in the
# commit range being pushed. Pushes to other remotes (e.g. a private gitlab) are not gated.
#
# Install:  cp bootstrap/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# (git args: $1 = remote name, $2 = remote URL; stdin lines: <local_ref> <local_sha> <remote_ref> <remote_sha>)
remote_url="$2"
case "$remote_url" in
  *github.com*) ;;            # guard only public github pushes
  *) exit 0 ;;
esac

root=$(git rev-parse --show-toplevel)
cfg="$root/.gitleaks-opsec.toml"
if [ ! -f "$cfg" ]; then
  echo "pre-push: $cfg not found -- cannot verify OPSEC; REFUSING github push." >&2; exit 1
fi
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-push: gitleaks not installed -- cannot verify OPSEC; REFUSING github push." >&2; exit 1
fi

zero=0000000000000000000000000000000000000000
status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue                      # branch deletion
  if [ "$remote_sha" = "$zero" ]; then range="$local_sha"; else range="$remote_sha..$local_sha"; fi
  if ! gitleaks detect --source "$root" -c "$cfg" --log-opts="$range" --redact --no-banner --exit-code 1 >/dev/null 2>&1; then
    echo "pre-push: OPSEC keyword scan found matches in $range -> REFUSING push to $remote_url" >&2
    echo "  Only the clean release line may reach github (see RELEASING.md). Push from a clean clone." >&2
    status=1
  fi
done
exit $status
