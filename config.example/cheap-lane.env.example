# Cheap-lane endpoint for `claude-cheap` (two-lane model handoff -- docs/two-lane-model-handoff.md).
# Copy to your PRIVATE config (e.g. ~/.config/claude-harness/cheap-lane.env) and fill real values.
# NEVER commit a real internal endpoint. For sensitive use the endpoint MUST be a host you control.

# Your self-hosted endpoint that speaks the Anthropic Messages API (/v1/messages).
# vLLM-native, or a LiteLLM / claude-code-router gateway in front of an OpenAI-only model.
CLAUDE_CHEAP_BASE_URL=http://localhost:8000

# The served model id (optional; omit to use the endpoint's default).
CLAUDE_CHEAP_MODEL=cheap

# Any non-empty string for a tokenless local endpoint (Claude Code requires an auth token to be set).
CLAUDE_CHEAP_TOKEN=local
